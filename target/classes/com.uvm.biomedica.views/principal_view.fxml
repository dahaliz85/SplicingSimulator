<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.uvm.biomedica.controller.MainController">
    <top>
        <HBox fx:id="barraSuperior" alignment="CENTER_LEFT" spacing="20.0" styleClass="header-area" BorderPane.alignment="CENTER">
            <children>
                <Label styleClass="app-title" text="🧬 COL3A1 Splicing Simulator v1.0" />
                <Button fx:id="btnCargarSano" mnemonicParsing="false" onAction="#handleCargarSano" styleClass="btn-secondary" text="📂 Cargar Secuencia Sana" />
                <Button fx:id="btnCargarMutado" mnemonicParsing="false" onAction="#handleCargarMutado" styleClass="btn-secondary" text="📂 Cargar Secuencia Mutada" />
                <Button fx:id="btnSimular" mnemonicParsing="false" onAction="#handleEjecutarSimulacion" styleClass="btn-primary" text="⚡ CORRER SIMULACIÓN" />
                <Label fx:id="lblEstado" styleClass="status-led" text="● Esperando archivos..." />
            </children>
            <padding>
                <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
            </padding>
        </HBox>
    </top>
    <center>
        <SplitPane dividerPositions="0.5" styleClass="mirror-split" BorderPane.alignment="CENTER">
            <items>
                <VBox spacing="10.0" styleClass="sequence-container">
                    <children>
                        <Label styleClass="section-header" text="Wildtype | COL3A1" />
                        <TableView fx:id="tblCoordenadasSanas" styleClass="table-view" prefHeight="150.0">
                            <columns>
                                <TableColumn fx:id="colExonSano" prefWidth="150.0" text="Elemento" />
                                <TableColumn fx:id="colRangoSano" prefWidth="250.0" text="Coordenadas (NCBI)" />
                            </columns>
                        </TableView>
                        <TextArea fx:id="txtSecuenciaSana" editable="false" prefHeight="350.0" styleClass="sequence-text-area" wrapText="true" />
                    </children>
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                </VBox>
                <VBox spacing="10.0" styleClass="sequence-container">
                    <children>
                        <Label styleClass="section-header" text="hEDS Variante | c.3818A&gt;G" />
                        <TableView fx:id="tblCoordenadasMutadas" prefHeight="150.0">
                            <columns>
                                <TableColumn fx:id="colExonMutado" prefWidth="150.0" text="Elemento" />
                                <TableColumn fx:id="colRangoMutado" prefWidth="250.0" text="Coordenadas (NCBI)" />
                            </columns>
                        </TableView>
                        <TextArea fx:id="txtSecuenciaMutada" editable="false" prefHeight="350.0" styleClass="sequence-text-area" wrapText="true" />
                    </children>
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                </VBox>
            </items>
        </SplitPane>
    </center>
    <bottom>
        <HBox alignment="CENTER_LEFT" prefHeight="180.0" spacing="40.0" styleClass="bottom-bar" BorderPane.alignment="CENTER">
            <children>
                <VBox alignment="CENTER_LEFT" spacing="10.0" prefWidth="250.0">
                    <children>
                        <Label styleClass="panel-label" text="Parámetros Monte Carlo:" />
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Label text="Iteraciones:" textFill="WHITE" />
                                <TextField fx:id="txtIteraciones" prefWidth="100.0" text="10000" styleClass="dark-field" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
                <LineChart fx:id="chrConvergencia" title="Convergencia Estadística de Splicing" HBox.hgrow="ALWAYS">
                    <xAxis>
                        <NumberAxis label="Iteraciones" side="BOTTOM" tickLabelFill="WHITE" />
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Eficiencia %" side="LEFT" tickLabelFill="WHITE" />
                    </yAxis>
                </LineChart>
                <VBox alignment="CENTER_LEFT" spacing="5.0" prefWidth="300.0" styleClass="results-box">
                    <children>
                        <Label styleClass="results-title" text="Resultados Clínicos:" />
                        <Label fx:id="lblEficienciaSana" styleClass="result-item" text="[ Eficiencia Sano: -- ]" />
                        <Label fx:id="lblEficienciaMutada" styleClass="result-item" text="[ Eficiencia Mutado: -- ]" />
                        <Label fx:id="lblDiagnostico" styleClass="result-item-alert" text="[ Diagnóstico: Esperando... ]" />
                    </children>
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                    </padding>
                </VBox>
            </children>
            <padding>
                <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
            </padding>
        </HBox>
    </bottom>
</BorderPane>